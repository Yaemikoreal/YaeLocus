# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf
*.pyi text eol=lf

# Configuration files
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ini text eol=lf
*.cfg text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Shell scripts
*.sh text eol=lf
*.bat text eol=crlf

# Data files (preserve original line endings)
*.csv text
*.xlsx binary
*.db binary

# Exclude from package
.github export-ignore
.gitignore export-ignore
.pytest_cache export-ignore
.venv export-ignore
tests export-ignore
*.egg-info export-ignore